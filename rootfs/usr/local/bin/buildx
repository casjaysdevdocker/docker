# @@Description      :  Docker buildx wrapper
# @@Changelog        :  New script
# @@TODO             :  Refactor code
# @@Other            :
# @@Resource         :
# @@Terminal App     :  no
# @@sudo/root        :  no
# @@Template         :  bash/system
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__buildx() {
  local exitStatus=0 reg_tag="${1:-$TAG_NAME}" dir="${directory:-.}"
  [ -n "$platforms" ] && build_platforms="--platform ${platforms// /,}"
  # - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
  # Initialize
  echo "Setting target platform to $platforms"
  echo "and setting buildername to $buildername"
  echo "Initializing $qemu_imagename $binfmt_imagename"
  __image_exists "$qemu_imagename" || docker run --pull -d --name "$qemu_imagename" --privileged multiarch/qemu-user-static --reset -p yes &>/dev/null || { echo "Failed to Initialize" && exit 1; }
  __image_exists "$binfmt_imagename" || docker run --pull -d --name "$binfmt_imagename" --privileged tonistiigi/binfmt --install all &>/dev/null || { echo "Failed to Initialize" && exit 1; }
  __image_exists "$buildername" || docker buildx create --name "$buildername" --use &>/dev/null || { echo "Failed to Initialize" && exit 1; }
  docker buildx use "$buildername" &>/dev/null || { echo "Failed to Initialize" && exit 1; }
  docker buildx inspect --bootstrap &>/dev/null || { echo "Failed to Initialize" && exit 1; }
  # - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
  # Build
  echo "Building $reg_tag"
  eval docker buildx build --rm --pull \
    --push --no-cache $build_platforms \
    --progress auto --output=type=registry \
    -t "$reg_tag" "$dir" || exitStatus=1
  [ "$exitStatus" -eq 0 ] || echo "Failed to build $reg_tag"
  # - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
  # Cleanup
  __image_exists "$buildername" && docker rm -f "$buildername" &>/dev/null
  __image_exists "$qemu_imagename" && docker rm -f "$qemu_imagename" &>/dev/null
  __image_exists "$binfmt_imagename" && docker rm -f "$binfmt_imagename" &>/dev/null
  return $exitStatus
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__image_exists() { docker ps -a 2>&1 | grep -q "$1" || return 1; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables
[ -f "$PWD/.env.sh" ] && . "$PWD/.env.sh"
[ -f "$1" ] && docker_file="$1" && shift 1 || docker_file="${docker_file:-}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
ADD_TAG="${*:-$TAG}"
TAG_NAME="${TAG_NAME:-$ADD_TAG}"
ADD_REG="${ADD_REG:-casjaysdevdocker}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
exitCode=0
buildername="mybuilder"
qemu_imagename="buildx-qemu"
binfmt_imagename="buildx-binfmt"
platforms="${PLATFORMS:-linux/amd64,linux/arm64}"
docker_files="$(find "/root/build" -name 'Dockerfile*' 2>/dev/null | grep '^' || false)"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
export DOCKER_CLI_EXPERIMENTAL="enabled"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
[ -n "$(pgrep -x dockerd)" ] || start-docker.sh &>/dev/null &
[ -n "$TAG_NAME" ] || { echo "USAGE: buildx [tagname]" && exit 1; }
[ -n "$docker_files" ] || { echo "No Dockerfile found in $HOME/build" && exit 1; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Main application
clear
if [ -n "$docker_file" ]; then
  directory="$(dirname "$file")"
  image_name="$(basename "$directory")"
  tag_name="$ADD_REG/$image_name:latest"
  cd "$directory" && __buildx "$tag_name" || exitCode+="$((exitCode + 1))"
elif [ -n "$docker_files" ]; then
  for file in $docker_files; do
    directory="$(dirname "$file")"
    image_name="$(basename "$directory")"
    tag_name="$ADD_REG/$image_name:latest"
    cd "$directory" && __buildx "$tag_name" || exitCode+="$((exitCode + 1))"
  done
else
  echo "Can not find a Dockerfile in /root/build"
  exitCode=10
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
exit $exitCode
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# end
